# Copy this file to .env and fill in secrets. (.env is gitignored.)

# Required: HydraDB API key from https://hydradb.com
HYDRADB_API_KEY=API_KEY_HERE

# API base URL (override only if Hydra documents a different host)
HYDRADB_BASE_URL=https://api.hydradb.com

# Tenant used for ingestion and recall demos
HYDRADB_TENANT_ID=espn-corpus

# Feedback sub-tenant for storing edited article pairs (Phase 4)
HYDRADB_FEEDBACK_TENANT_ID=edited-outputs

# Knowledge file path, relative to the project root (DocRay/)
HYDRADB_KNOWLEDGE_JSON=nba_news.json

# Recall smoke-test query
HYDRADB_RECALL_QUERY=NBA playoff recap

# Polling intervals (Python script uses POLL_SECONDS; Node uses POLL_INTERVAL_MS)
HYDRADB_POLL_SECONDS=2
HYDRADB_POLL_INTERVAL_MS=2000

# LLM provider (Phase 3+)
GMI_CLOUD_API_KEY=your-gmi-cloud-api-key
GMI_CLOUD_BASE_URL=https://api.gmi-serving.com/v1
GMI_CLOUD_MODEL=deepseek-ai/DeepSeek-V3.2
